# Visual Mapper - Environment Configuration
# Copy this file to .env and customize as needed

# Connection Monitoring Configuration
# ====================================

# How often to check device health (in seconds)
# - Production: 30 (default)
# - Dev/Testing: 5-10 (faster detection)
# - Range: 5-300
CONNECTION_CHECK_INTERVAL=30

# Maximum backoff delay for reconnection retries (in seconds)
# - Production: 300 (5 minutes, default)
# - Dev/Testing: 60 (1 minute)
# - Range: 60-600
CONNECTION_MAX_RETRY_DELAY=300

# Enable/disable automatic reconnection
# - Production: true (default)
# - Testing: false (to test manual reconnection)
CONNECTION_RETRY_ENABLED=true

# Security & Access
# =================

# API key for companion app or remote clients
# Leave empty to disable auth (development only)
COMPANION_API_KEY=

# Trust X-Forwarded-For from a reverse proxy
# Set to true only if you control the proxy
TRUST_PROXY_HEADERS=false

# CORS Configuration (comma-separated list of allowed origins)
# Example: http://localhost:8080,http://127.0.0.1:8080
CORS_ALLOW_ORIGINS=
CORS_ALLOW_CREDENTIALS=false

# MQTT Defaults
# =============
MQTT_BROKER=localhost
MQTT_PORT=1883

# Example Dev Mode Configuration
# ===============================
# Uncomment these for faster testing:
# CONNECTION_CHECK_INTERVAL=5
# CONNECTION_MAX_RETRY_DELAY=60
